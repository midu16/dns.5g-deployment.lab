# Copy to .env and adjust for your lab host.
# Generate TSIG keys: deploy/compose/scripts/generate-tsig.sh

POSTGRES_USER=pdns
POSTGRES_PASSWORD=changeme-pdns-db
POSTGRES_DB=pdns

PDNS_API_KEY=changeme-pdns-api-key

# TSIG key for AXFR/NOTIFY (name + base64 secret)
TSIG_KEY_NAME=axfr-key.
TSIG_KEY_SECRET=changeme-base64-tsig-secret

# Lab network CIDR allowed to recurse
RECURSIVE_ACL=10.89.0.0/24,127.0.0.0/8,172.16.0.0/12

# Auth VIP address used in zone NS records (dnsdist-auth on auth_net)
AUTH_VIP=10.89.2.10

# v2: dnsdist policy modules (comma-separated basenames under config/dnsdist/policies/)
DNSDIST_POLICIES=split-horizon,blocklist

# v2: dual-primary active writer (A or B)
PDNS_ACTIVE_PRIMARY=A
PDNS_PRIMARY=pdns-primary

# v2: PostgreSQL replication (profile ha)
POSTGRES_REPLICATION_PASSWORD=changeme-replica

# v2: anycast lab
ANYCAST_VIP=10.89.99.53
ANYCAST_LAB_MODE=anycast

# GitOps controller (OctoDNS reconciler)
GITOPS_SYNC_INTERVAL=60
GITOPS_AUTO_APPLY=true
GIT_REPO_URL=
GIT_BRANCH=main
GITOPS_WEBHOOK_ENABLED=true
GITOPS_WEBHOOK_PORT=8088
GITOPS_WEBHOOK_TOKEN=
